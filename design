module multiplier_2(
    input clk,
    input signed [1:0] A,
    input signed [1:0] B,
    output reg signed [3:0] P
);

    reg signed [1:0] A_reg, B_reg;

    always @(posedge clk) begin
        A_reg <= A;
        B_reg <= B;
        P <= A_reg * B_reg;
    end

endmodule

module multiplier_2bit(
    input  signed [1:0] A,   
    input  signed [1:0] B,  
    output signed [3:0] P    // Product
);

    assign P = A * B;

endmodule
