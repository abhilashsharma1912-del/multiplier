module multiplier_16(
    input clk,
    input signed [15:0] A,
    input signed [15:0] B,
    output reg signed [31:0] P
);

    reg signed [15:0] A_reg, B_reg;

    always @(posedge clk) begin
        A_reg <= A;
        B_reg <= B;
        P <= A_reg * B_reg;
    end

endmodule

module multiplier_16bit(
    input  signed [15:0] A,   // ECG sample
    input  signed [15:0] B,   // FIR coefficient
    output signed [31:0] P    // Product
);

    assign P = A * B;

endmodule
